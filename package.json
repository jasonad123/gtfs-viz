{
  "name": "gtfs-viz",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "description": "Interactive GTFS visualization and editing tool running entirely in your browser",
  "repository": {
    "type": "git",
    "url": "https://github.com/jasonad123/gtfs-viz.git"
  },
  "keywords": [
    "gtfs",
    "transit",
    "visualization",
    "maps",
    "duckdb",
    "webassembly",
    "react",
    "deck.gl"
