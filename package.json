    "lint": "eslint .",
    "preview": "vite preview",
    "postinstall": "node scripts/fix-duckdb-sourcemaps.mjs",
    "version": "echo v$(node -p \"require('./package.json').version\")",
    "release:patch": "npm version patch -m 'chore: release v%s'",
